# Serverspezifische Befehle fuer deploy.sh
#
# Diese Datei nach "deploy.env" kopieren und die passenden Zeilen einkommentieren.
# deploy.env selbst gehoert NICHT ins Repo (steht in .gitignore) - sie beschreibt
# nur diesen einen Server.

# ---------------------------------------------------------------------------
# Plesk (z. B. RAV / intranet.ravensberger-matratzen.de)
# Das System-php ist dort 8.3 - deshalb IMMER der volle Pfad zur 8.5.
# Composer liegt als composer.phar im Projektverzeichnis.
# ---------------------------------------------------------------------------
# PHP=/opt/plesk/php/8.5/bin/php
# COMPOSER="/opt/plesk/php/8.5/bin/php ./composer.phar"
# NPM=npm

# ---------------------------------------------------------------------------
# Ubuntu-VM (z. B. Waldorfschule)
# ---------------------------------------------------------------------------
# PHP=/usr/bin/php8.4
# COMPOSER=composer
# NPM=npm
